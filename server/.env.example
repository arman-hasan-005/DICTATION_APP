# ── Required ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dictaclass
JWT_SECRET=your_long_random_secret_minimum_32_characters_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorised redirect URI must include: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP (for OTP + password reset) ───────────────────────────────────
# Gmail: use an App Password (not your regular password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=DictaClass <your@gmail.com>

# ── Google Cloud TTS (optional) ───────────────────────────────────────────────
# Without this, uploaded-content dictation falls back to browser speech
GOOGLE_TTS_KEY=

# ── Google Vision API (for handwriting OCR) ───────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: "Cloud Vision API" on the project first
# The same API key used for TTS can be reused if both APIs are enabled on it.
GOOGLE_VISION_KEY=
