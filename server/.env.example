# ── Required ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dictaclass
JWT_SECRET=your_long_random_jwt_secret_minimum_32_chars_here

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # Set to 'production' in deployed environments
CLIENT_URL=http://localhost:5173  # Allowed CORS origin in production

# Google Cloud TTS (optional — browser speech used as fallback if unset)
GOOGLE_TTS_KEY=
